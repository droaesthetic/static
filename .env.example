DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-bot-application-client-id
DISCORD_GUILD_ID=
LAVALINK_NAME=main
LAVALINK_URL=127.0.0.1:2333
# Must match lavalink/application.yml -> lavalink.server.password (same default there for local runs)
LAVALINK_PASSWORD=droTunesLocalLava2026!
LAVALINK_SECURE=false
# Optional: used for official YouTube Data API search metadata. Audio still plays through Lavalink.
YOUTUBE_API_KEY=
# Used by the bot resolver and passed to Lavalink’s LavaSrc plugin when using lavalink/start-lavalink.ps1 (loads these into PLUGINS_LAVASRC_SPOTIFY_*)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
DASHBOARD_PORT=3000
DASHBOARD_PUBLIC_URL=http://localhost:3000
DASHBOARD_AUTH_TOKEN=replace-with-a-long-random-secret
# Stripe Billing for $4.99/month premium subscriptions.
# Create a recurring monthly Price in Stripe for 499 USD cents and put its price_... id here.
STRIPE_SECRET_KEY=
STRIPE_PREMIUM_PRICE_ID=
# Required in production. From Stripe webhook endpoint signing secret.
STRIPE_WEBHOOK_SECRET=
# Optional: one Discord user ID that can use premium solo without a subscription.
PREMIUM_SOLO_USER_ID=
BOT_OWNERS=123456789012345678
BOT_MANAGERS=
DEFAULT_VOLUME=75
MAX_QUEUE_SIZE=100
CHAT_COMMAND_DELETE_AFTER_SECONDS=30
