    "express": "^4.21.2",
    "play-dl": "^1.9.7",
    "shoukaku": "^4.3.0",
    "undici": "^7.8.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
