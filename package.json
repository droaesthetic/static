  "type": "module",
  "description": "Discord music bot with slash commands, multi-provider link resolution, and a web dashboard.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:local": "node dist/index.js",
