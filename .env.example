DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-bot-application-client-id
DISCORD_GUILD_ID=
LAVALINK_NAME=main
LAVALINK_URL=127.0.0.1:2333
# Must match lavalink/application.yml -> lavalink.server.password (same default there for local runs)
LAVALINK_PASSWORD=droTunesLocalLava2026!
LAVALINK_SECURE=false
LAVALINK_RESUME_TIMEOUT_SECONDS=120
LAVALINK_RECONNECT_TRIES=20
LAVALINK_RECONNECT_INTERVAL_SECONDS=5
LAVALINK_REST_TIMEOUT_SECONDS=30
LAVALINK_VOICE_CONNECTION_TIMEOUT_SECONDS=45
# Optional: used for official YouTube Data API search metadata. Audio still plays through Lavalink.
YOUTUBE_API_KEY=
# Optional: lets Lavalink's YouTube source use OAuth for age-restricted videos.
# For first-time setup, set YOUTUBE_OAUTH_ENABLED=true and YOUTUBE_OAUTH_SKIP_INITIALIZATION=false,
# start Lavalink, complete the device-code flow shown in the Lavalink terminal, then paste the emitted refresh token here.
YOUTUBE_OAUTH_ENABLED=false
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_OAUTH_SKIP_INITIALIZATION=true
# Optional: Alternative to OAuth. Proof of Origin Token (poToken) generated via external tools.
YOUTUBE_POT_TOKEN=
YOUTUBE_POT_VISITORDATA=
# Used by the bot resolver and passed to Lavalink’s LavaSrc plugin when using lavalink/start-lavalink.ps1 (loads these into PLUGINS_LAVASRC_SPOTIFY_*)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
DASHBOARD_PORT=3000
DASHBOARD_PUBLIC_URL=http://localhost:3000
DASHBOARD_AUTH_TOKEN=replace-with-a-long-random-secret
# Stripe Billing for $3.99/month premium subscriptions.
# Create a recurring monthly Price in Stripe for 399 USD cents and put its price_... id here.
# Enable Stripe Billing Customer Portal so existing subscribers can manage or cancel from /subscribe.
STRIPE_SECRET_KEY=
STRIPE_PREMIUM_PRICE_ID=
# Required in production. From Stripe webhook endpoint signing secret.
STRIPE_WEBHOOK_SECRET=
# Optional: one Discord user ID that can use premium solo without a subscription.
PREMIUM_SOLO_USER_ID=
BOT_OWNERS=123456789012345678
BOT_MANAGERS=
DEFAULT_VOLUME=75
MAX_QUEUE_SIZE=100
CHAT_COMMAND_DELETE_AFTER_SECONDS=30
# Keeps background traffic low by default: shorter idle voice sessions, slower playback health checks,
# and no external artwork thumbnails in now-playing embeds.
LOW_BANDWIDTH_MODE=true
IDLE_VOICE_DISCONNECT_SECONDS=45
PLAYBACK_WATCHDOG_INTERVAL_SECONDS=15
STALE_PLAYER_UPDATE_SECONDS=45
NOW_PLAYING_THUMBNAILS=false
PRE_RESOLVE_NEXT_TRACK=true
# Makes the Now Playing embed behave like a sticky message (re-sent at the bottom on chat activity)
STICKY_NOW_PLAYING=false
