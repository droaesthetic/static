DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-bot-application-client-id
DISCORD_GUILD_ID=
LAVALINK_NAME=main
LAVALINK_URL=127.0.0.1:2333
# Must match lavalink/application.yml -> lavalink.server.password (same default there for local runs)
LAVALINK_PASSWORD=droTunesLocalLava2026!
LAVALINK_SECURE=false
# Used by the bot resolver and passed to Lavalink’s LavaSrc plugin when using lavalink/start-lavalink.ps1 (loads these into PLUGINS_LAVASRC_SPOTIFY_*)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
DASHBOARD_PORT=3000
DASHBOARD_PUBLIC_URL=http://localhost:3000
DASHBOARD_AUTH_TOKEN=replace-with-a-long-random-secret
BOT_OWNERS=123456789012345678
DEFAULT_VOLUME=75
MAX_QUEUE_SIZE=100
CHAT_COMMAND_DELETE_AFTER_SECONDS=30
